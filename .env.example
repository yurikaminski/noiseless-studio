# ──────────────────────────────────────────────
#  Noiseless Studio — Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to git.
# ──────────────────────────────────────────────

# ── Google AI (Gemini / Veo) ─────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Google OAuth (Drive + Sheets) ────────────
# Download OAuth 2.0 credentials from Google Cloud Console
# and save them to credentials/oauth_client.json
GOOGLE_OAUTH_CLIENT_FILE=./credentials/oauth_client.json
GOOGLE_TOKEN_FILE=./credentials/token.json

# ── Server ───────────────────────────────────
# Port for the Express backend (Railway sets this automatically)
PORT=3001

# ── Production only (Railway) ────────────────
# Mount a persistent volume at /data in Railway and set:
# DATA_DIR=/data
#
# This stores both the SQLite database and uploaded files
# in the persistent volume so they survive deploys.
# DATA_DIR=/data

# ── Production only (CORS) ───────────────────
# Set to your Vercel frontend URL so the backend allows requests from it.
# You can add multiple URLs separated by commas.
# FRONTEND_URL=https://your-app.vercel.app

# ── User Auth (OAuth Login + Sessions) ───────
# OAuth redirect URI for the login flow (different from Drive OAuth)
# Local:      http://localhost:3001/api/user/auth/callback
# Production: https://your-backend.railway.app/api/user/auth/callback
LOGIN_REDIRECT_URI=http://localhost:3001/api/user/auth/callback

# 64-byte random hex secret for signing JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_BYTE_HEX_STRING

# Session duration in seconds (default: 86400 = 24 hours)
SESSION_DURATION_SECONDS=86400

# ── Email (Resend) ────────────────────────────
# Sign up at https://resend.com and get your API key
# Verify a sending domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Public URL of your frontend app — used in email links
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
APP_URL=http://localhost:5173
