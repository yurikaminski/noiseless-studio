# ──────────────────────────────────────────────
#  Noiseless Studio — Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to git.
# ──────────────────────────────────────────────

# ── Google AI (Gemini / Veo) ─────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Google OAuth (Drive + Sheets) ────────────
# Download OAuth 2.0 credentials from Google Cloud Console
# and save them to credentials/oauth_client.json
GOOGLE_OAUTH_CLIENT_FILE=./credentials/oauth_client.json
GOOGLE_TOKEN_FILE=./credentials/token.json

# ── Server ───────────────────────────────────
# Port for the Express backend (Railway sets this automatically)
PORT=3001

# ── Production only (Railway) ────────────────
# Mount a persistent volume at /data in Railway and set:
# DATA_DIR=/data
#
# This stores both the SQLite database and uploaded files
# in the persistent volume so they survive deploys.
# DATA_DIR=/data

# ── Production only (CORS) ───────────────────
# Set to your Vercel frontend URL so the backend allows requests from it.
# You can add multiple URLs separated by commas.
# FRONTEND_URL=https://your-app.vercel.app
