{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RAILWAY_APP.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR_RAILWAY_APP.railway.app/uploads/:path*"
    }
  ]
}
